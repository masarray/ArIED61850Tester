<Window x:Class="ArIED61850Tester.SaveSclWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save SCL" Height="290" Width="500" MinHeight="290" MinWidth="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}"
        FontFamily="Aptos, Segoe UI Variable Text, Segoe UI, Calibri"
        Icon="Assets/app-icon.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2" Text="Save interoperable SCL" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>

                <TextBlock Grid.Row="1" Text="IED" Margin="0,16,0,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding IedName}" Margin="0,16,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>

                <TextBlock Grid.Row="2" Text="Source" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SourceDescription}" Margin="0,12,0,0" VerticalAlignment="Center" Foreground="{StaticResource Ink}" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3" Text="Edition" Margin="0,14,0,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,14,0,0">
                    <ComboBox ItemsSource="{Binding SchemaProfiles}"
                              SelectedItem="{Binding SelectedSchemaProfile}"
                              DisplayMemberPath="DisplayName"/>
                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                               Text="Edition 2 is saved as IID. Edition 1 is saved as ICD. A JSON evidence report and Markdown summary are written beside the SCL file."/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource SoftButton}" IsCancel="True" MinWidth="96" Margin="0,0,8,0"/>
            <Button Content="Save SCL" Style="{StaticResource PrimaryButton}" IsDefault="True" MinWidth="112" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
